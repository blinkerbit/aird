{
  "name": "aird-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend build tooling for Aird (dev-only, not shipped)",
  "scripts": {
    "css:build": "npx @tailwindcss/cli -i ./src/input.css -o ./aird/static/css/app.css --minify",
    "css:watch": "npx @tailwindcss/cli -i ./src/input.css -o ./aird/static/css/app.css --watch",
    "lint:js": "eslint aird/static/js",
    "js:share": "esbuild aird/static/js/share/src/main.js --bundle --platform=browser --format=iife --outfile=aird/static/js/share/app.js",
    "js:share:watch": "esbuild aird/static/js/share/src/main.js --bundle --platform=browser --format=iife --outfile=aird/static/js/share/app.js --watch",
    "vendor:qrcode": "esbuild node_modules/qrcode/lib/browser.js --bundle --platform=browser --format=iife --global-name=AirdQRCode --outfile=aird/static/js/vendor/qrcode-browser.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4",
    "daisyui": "^5",
    "eslint": "^9",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^15",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4",
    "esbuild": "^0.25.12"
  }
}
